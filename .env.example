# Postgres credentials used by the db service in docker-compose
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# connection string used by the api to connect to the database
DATABASE_URL=postgresql://user:password@db:5432/dbname

# default: 3000
PORT=

# path to the shared log file (default: /app/logs/app.log)
LOG_PATH=

# development / production
NODE_ENV=